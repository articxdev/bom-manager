// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Component {
  id                String   @id @default(cuid())
  name              String   @unique
  category          String
  unit              String   // e.g., "pcs", "meter", "gram"
  currentStock      Int      @default(0)
  reorderThreshold  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  enteredBy         String?  // Who created it

  bomItems      BOMItem[]
  transactions  Transaction[]

  @@index([category])
  @@index([currentStock])
}

model Product {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enteredBy   String?  // Who created it

  bomItems     BOMItem[]
  transactions Transaction[]

  @@index([name])
}

model BOMItem {
  id              String   @id @default(cuid())
  productId       String
  componentId     String
  quantityPerUnit Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([productId, componentId])
  @@index([productId])
  @@index([componentId])
}

model Transaction {
  id                      String   @id @default(cuid())
  componentId             String
  type                    String   // PRODUCTION, DAMAGE, STOCK_IN, MANUAL_ADJUST, REVERSAL (SQLite doesn't support enums)
  quantityChange          Int
  resultingBalance        Int
  productId               String?
  productionQuantity      Int?         // units produced if PRODUCTION type
  note                    String?
  enteredBy               String?
  createdAt               DateTime @default(now())
  reversedTransactionId   String?  @unique // self-relation for reversals (unique for one-to-one)

  component              Component      @relation(fields: [componentId], references: [id], onDelete: Cascade)
  product                Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  reversalTransaction    Transaction?   @relation("Reversal", fields: [reversedTransactionId], references: [id], onDelete: SetNull)
  reversedByTransaction  Transaction?   @relation("Reversal")

  @@index([componentId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@index([reversedTransactionId])
}
